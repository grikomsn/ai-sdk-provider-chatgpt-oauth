{
  "name": "chatgpt-oauth-example",
  "version": "2.0.0",
  "private": true,
  "description": "Example OAuth implementation for ChatGPT without Codex CLI",
  "type": "module",
  "scripts": {
    "login": "tsx src/auth-cli.ts login",
    "logout": "tsx src/auth-cli.ts logout",
    "status": "tsx src/auth-cli.ts status",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/test.ts",
    "example": "tsx src/example-app.ts",
    "dev": "tsx --watch src/example-app.ts"
  },
  "dependencies": {
    "@grikomsn/ai-sdk-provider-chatgpt-oauth": "file:..",
    "ai": "7.0.26",
    "dotenv": "17.4.2",
    "open": "11.0.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=22"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
